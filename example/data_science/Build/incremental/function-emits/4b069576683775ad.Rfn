Sym_1 <- function() 
{
  obs <- c(0.9, 1.8, 2.7, 4.1, 5.2, 5.8, 7.1, 8.0)
  x <- 0.0
  p <- 1.0
  q <- 0.05
  r <- 0.2
  i <- 1.0
  repeat {
    if (!(i <= length(obs))) break
    p <- (p + q)
    k <- (p / (p + r))
    x <- (x + (k * (obs[i] - x)))
    p <- ((1.0 - k) * p)
    i <- (i + 1.0)
    next
  }
  rr_mark(17L, 5L);
  Sym_11("kalman_state", x)
  return(Sym_11("kalman_var", p))
}
