import "../common/sim_utils.rr"

fn main() {
    let obs = c(0.9, 1.8, 2.7, 4.1, 5.2, 5.8, 7.1, 8.0)
    let x = 0.0
    let p = 1.0
    let q = 0.05
    let r = 0.20
    let i = 1.0
    while (i <= length(obs)) {
        p = p + q
        let k = p / (p + r)
        x = x + k * (obs[i] - x)
        p = (1.0 - k) * p
        i += 1.0
    }
    print_metric("kalman_state", x)
    print_metric("kalman_var", p)
}

main()
