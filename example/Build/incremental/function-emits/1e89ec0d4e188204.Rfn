  # rr-cse-pruned
  w2 <- (a2 / sum_a)
  # rr-cse-pruned
  w3 <- (a3 / sum_a)
  q1 <- (((0.3333 * .arg_v_m2) - (1.1666 * .arg_v_m1)) + (1.8333 * .arg_v_c))
  q2 <- (((-0.1666 * .arg_v_m1) + (0.8333 * .arg_v_c)) + (0.3333 * .arg_v_p1))
  q3 <- (((0.3333 * .arg_v_c) + (0.8333 * .arg_v_p1)) - (0.1666 * .arg_v_p2))
  return((((w1 * q1) + (w2 * q2)) + (w3 * q3)))
}
