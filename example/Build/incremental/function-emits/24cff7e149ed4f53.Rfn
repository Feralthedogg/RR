Sym_117 <- function(a, b, n) 
{
  .arg_a <- a
  .arg_b <- b
  .arg_n <- n
  sum <- 0.0
  i <- 1.0
  # rr-cse-pruned
  repeat {
    if (!(i <= .arg_n)) break
    ii <- floor(i)
    sum <- (sum + (rr_index1_read(.arg_a, ii, "index") * rr_index1_read(.arg_b, ii, "index")))
    i <- (i + 1.0)
    next
  }
  return(sum)
}
