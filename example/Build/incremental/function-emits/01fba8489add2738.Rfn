Sym_207 <- function(x, y, w, h) 
{
  .arg_x <- x
  .arg_y <- y
  .arg_w <- w
  .arg_h <- h
  xx <- .arg_x
  yy <- .arg_y
  if ((xx < 1.0)) {
    xx <- .arg_w
  } else {
  }
  if ((xx > .arg_w)) {
    xx <- 1.0
  } else {
  }
  if ((yy < 1.0)) {
    yy <- h
  } else {
  }
  if ((yy > .arg_h)) {
    yy <- 1.0
  } else {
  }
  return((((yy - 1.0) * .arg_w) + xx))
}
