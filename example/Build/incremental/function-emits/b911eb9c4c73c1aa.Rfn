Sym_183 <- function(n) 
{
  .arg_n <- n
  p <- seq_len(.arg_n)
  i <- 1.0
  seed <- 12345.0
  repeat {
    if (!(i <= .arg_n)) break
    seed <- (((seed * 1103515245.0) + 12345.0) %% 2147483648.0)
    rr_mark(753L, 9L);
    p[i] <- (seed / 2147483648.0)
    i <- (i + 1.0)
    next
  }
  return(p)
}
