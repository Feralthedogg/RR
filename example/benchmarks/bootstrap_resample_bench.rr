import "../common/sim_utils.rr";

fn main() {
    n = 128.0
    samples = rep.int(0.0, n)
    draws = lcg_uniform(8192.0, 4242.0)
    i = 1.0
    while (i <= n) {
        samples[i] = i * 0.2 + (i % 7.0) * 0.05
        i += 1.0
    }
    resample = 1.0
    acc = 0.0
    while (resample <= 96.0) {
        inner = 1.0
        s = 0.0
        while (inner <= n) {
            idx = unit_index(draws[(resample - 1.0) * n + inner], n)
            s += samples[idx]
            inner += 1.0
        }
        acc += s / n
        resample += 1.0
    }
    print_metric("bootstrap_bench_mean", acc / 96.0)
    print_metric("bootstrap_bench_acc", acc)
}

main();
