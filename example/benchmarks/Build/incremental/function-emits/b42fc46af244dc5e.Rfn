Sym_6 <- function(n, seed) 
{
  .arg_n <- n
  .arg_seed <- seed
  out <- rep.int(0.0, .arg_n)
  s <- .arg_seed
  i <- 1.0
  repeat {
    if (!(i <= .arg_n)) break
    s <- (((s * 1103515245.0) + 12345.0) %% 2147483648.0)
    rr_mark(107L, 9L);
    out[i] <- (s / 2147483648.0)
    i <- (i + 1.0)
    next
  }
  return(out)
}
