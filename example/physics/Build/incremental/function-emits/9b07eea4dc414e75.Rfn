Sym_1 <- function() 
{
  theta <- 1.1
  omega <- 0.0
  dt <- 0.05
  damp <- 0.06
  g_over_l <- 1.0
  step <- 1.0
  repeat {
    if (!(step <= 160.0)) break
    alpha <- ((0.0 - (g_over_l * theta)) - (damp * omega))
    omega <- (omega + (dt * alpha))
    theta <- (theta + (dt * omega))
    step <- (step + 1.0)
    next
  }
  energy <- (((0.5 * omega) * omega) + ((0.5 * theta) * theta))
  rr_mark(17L, 5L);
  Sym_10("pendulum_theta", theta)
  return(Sym_10("pendulum_energy", energy))
}
