import "../common/sim_utils.rr"

fn main() {
    theta = 1.1
    omega = 0.0
    dt = 0.05
    damp = 0.06
    g_over_l = 1.0
    step = 1.0
    while (step <= 160.0) {
        alpha = 0.0 - g_over_l * theta - damp * omega
        omega = omega + dt * alpha
        theta = theta + dt * omega
        step += 1.0
    }
    energy = 0.5 * omega * omega + 0.5 * theta * theta
    print_metric("pendulum_theta", theta)
    print_metric("pendulum_energy", energy)
}

main()
