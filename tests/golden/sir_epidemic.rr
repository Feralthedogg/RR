import "../../example/common/sim_utils.rr"

fn main() {
    s = 999.0
    i = 1.0
    r = 0.0
    beta = 0.30
    gamma = 0.08
    n = 1000.0
    peak_i = i
    step = 1.0
    while (step <= 40.0) {
        new_inf = beta * s * i / n
        new_rec = gamma * i
        s = s - new_inf
        i = i + new_inf - new_rec
        r = r + new_rec
        peak_i = max1(peak_i, i)
        step += 1.0
    }
    print_metric("sir_peak_infected", peak_i)
    print_metric("sir_final_recovered", r)
}

main()
