import "../../example/common/sim_utils.rr";

fn main() {
    data = c(3.0, 4.0, 5.0, 6.0, 8.0, 9.0, 10.0, 11.0)
    sample_n = length(data)
    draws = 32.0
    uniforms = lcg_uniform(draws * sample_n, 24680.0)
    means = rep.int(0.0, draws)
    cursor = 1.0
    d = 1.0
    while (d <= draws) {
        s = 0.0
        j = 1.0
        while (j <= sample_n) {
            pick = unit_index(uniforms[cursor], sample_n)
            s += data[pick]
            cursor += 1.0
            j += 1.0
        }
        means[d] = s / sample_n
        d += 1.0
    }
    print_metric("bootstrap_base_mean", vector_mean(data))
    print_metric("bootstrap_resample_mean", vector_mean(means))
}

main();
